fibe_e2e_json_value() {
  fibe_e2e_json="$1"
  fibe_e2e_key="$2"
  fibe_e2e_default="$3"
  if [ -z "$fibe_e2e_json" ]; then
    printf '%s\n' "$fibe_e2e_default"
    return 0
  fi

  fibe_e2e_raw="$(
    printf '%s' "$fibe_e2e_json" |
      tr '\n' ' ' |
      sed -nE 's/.*"'"$fibe_e2e_key"'"[[:space:]]*:[[:space:]]*("[^"]*"|[^,}]*).*/\1/p' |
      head -n 1 |
      sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
  )"
  if [ -z "$fibe_e2e_raw" ]; then
    printf '%s\n' "$fibe_e2e_default"
    return 0
  fi

  case "$fibe_e2e_raw" in
    \"*\")
      fibe_e2e_raw="${fibe_e2e_raw#\"}"
      fibe_e2e_raw="${fibe_e2e_raw%\"}"
      printf '%s\n' "$fibe_e2e_raw" | sed 's/\\"/"/g; s/\\\\/\\/g'
      ;;
    null) printf '\n' ;;
    *) printf '%s\n' "$fibe_e2e_raw" ;;
  esac
}

fibe_e2e_group_value() {
  case "$1" in
    FIBE_E2E_TIMEOUTS) printf '%s\n' "${FIBE_E2E_TIMEOUTS:-${DOCKER_E2E_TIMEOUTS:-}}" ;;
    FIBE_E2E_PARALLELISM) printf '%s\n' "${FIBE_E2E_PARALLELISM:-${DOCKER_E2E_PARALLELISM:-}}" ;;
    FIBE_E2E_SETTINGS) printf '%s\n' "${FIBE_E2E_SETTINGS:-${DOCKER_E2E_SETTINGS:-}}" ;;
    *) printf '\n' ;;
  esac
}

fibe_e2e_group_defaults() {
  case "$1" in
    FIBE_E2E_TIMEOUTS) printf '%s\n' "$FIBE_E2E_TIMEOUTS_DEFAULTS" ;;
    FIBE_E2E_PARALLELISM) printf '%s\n' "$FIBE_E2E_PARALLELISM_DEFAULTS" ;;
    FIBE_E2E_SETTINGS) printf '%s\n' "$FIBE_E2E_SETTINGS_DEFAULTS" ;;
    *) printf '\n' ;;
  esac
}

fibe_e2e_export_json() {
  fibe_e2e_group="$1"
  fibe_e2e_key="$2"
  fibe_e2e_var="$3"
  fibe_e2e_group_default="$(fibe_e2e_group_defaults "$fibe_e2e_group")"
  fibe_e2e_default="$(fibe_e2e_json_value "$fibe_e2e_group_default" "$fibe_e2e_key" "")"
  fibe_e2e_value="$(fibe_e2e_json_value "$(fibe_e2e_group_value "$fibe_e2e_group")" "$fibe_e2e_key" "$fibe_e2e_default")"
  export "$fibe_e2e_var=$fibe_e2e_value"
}

